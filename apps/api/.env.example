# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://goalforge:goalforge_dev@localhost:5432/goalforge

# ---------------------------------------------------------------------------
# Redis (used by rate-limiting, Celery broker & result backend)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# AI
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Clerk authentication
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_JWKS_URL=https://your-frontend-api-url.clerk.accounts.dev/.well-known/jwks.json

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# App behaviour
# ---------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------------------------
# Internal API keys
# ---------------------------------------------------------------------------
# Required — jobs endpoint returns 401 if unset (no dev bypass)
JOBS_API_KEY=your_jobs_api_key_here

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key_here
# If set, all outgoing emails are redirected here (useful in dev/staging)
DEV_EMAIL_OVERRIDE=

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# ---------------------------------------------------------------------------
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com

# ---------------------------------------------------------------------------
# Database connection pool (optional — defaults shown)
# ---------------------------------------------------------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
