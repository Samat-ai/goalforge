DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/goalforge
GEMINI_API_KEY=your_gemini_api_key_here
# --- OR bill Gemini via Vertex AI (GCP credits) instead of the API key ---
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# Path to service-account JSON (role: Vertex AI User). Relative to apps/api
# locally; docker-compose mounts apps/api/secrets at /app/secrets so the same
# relative path works in the container too. NEVER commit this file.
# GOOGLE_APPLICATION_CREDENTIALS=secrets/vertex-sa.json
DEBUG=false
CLERK_SECRET_KEY="sk_test_your_secret_key_here"
CLERK_JWKS_URL="https://your-frontend-api-url.clerk.accounts.dev/.well-known/jwks.json"
CORS_ORIGINS="http://localhost:5173"
ENVIRONMENT=development
# Required — jobs endpoint returns 401 if unset (no dev bypass)
JOBS_API_KEY=your_jobs_api_key_here
# Owner inbox for user feedback notifications; if empty, feedback is stored but only logged
FEEDBACK_NOTIFY_EMAIL=
# Sentry error tracking; if empty, Sentry is disabled (leave empty in local dev)
SENTRY_DSN=